---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Download" description="Track working hours transparently and anonymously. For healthcare workers.">
  <Fragment slot="head">
    <meta property="og:title" content="Open Working Hours — Download" />
    <meta property="og:description" content="Track working hours transparently and anonymously. For healthcare workers." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://openworkinghours.org/download" />
    <meta property="og:image" content="https://openworkinghours.org/og-download.png" />
    <meta property="og:locale" content="en_US" />
  </Fragment>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Header -->
    <header class="mb-12 text-center">
      <h1 class="text-stone-900 mb-4">Get Open Working Hours</h1>
      <p class="text-xl text-stone-600 max-w-2xl mx-auto">
        Privacy-first working hours tracking for healthcare professionals. Track your shifts, contribute to collective insights — anonymously.
      </p>
    </header>

    <!-- Store badges -->
    <section class="mb-16">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8">
        <!-- App Store badge -->
        <div class="flex flex-col items-center gap-2">
          <a href="https://apps.apple.com/app/id6755491395" target="_blank" rel="noopener" class="inline-flex items-center gap-3 bg-stone-900 text-white px-6 py-3 rounded-xl hover:bg-stone-800 transition-colors" aria-label="Download on the App Store">
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div class="text-left">
              <div class="text-[10px] uppercase tracking-wide opacity-80">Download on the</div>
              <div class="text-lg font-semibold leading-tight">App Store</div>
            </div>
          </a>
        </div>

        <!-- Google Play badge -->
        <div class="flex flex-col items-center gap-2">
          <a class="opacity-50 pointer-events-none inline-flex items-center gap-3 bg-stone-900 text-white px-6 py-3 rounded-xl hover:bg-stone-800 transition-colors" aria-label="Get it on Google Play">
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.18 23.74c-.41-.22-.68-.65-.68-1.12V1.38C2.5.91 2.77.48 3.18.26l11.05 11.74L3.18 23.74zM14.89 12.66l2.56 2.72-8.27 4.7 5.71-7.42zM20.16 10.12c.56.32.84.82.84 1.38s-.28 1.06-.84 1.38l-2.53 1.44-2.82-2.82 2.82-2.82 2.53 1.44zM9.18 4.92l8.27 4.7-2.56 2.72-5.71-7.42z"/>
            </svg>
            <div class="text-left">
              <div class="text-[10px] uppercase tracking-wide opacity-80">Get it on</div>
              <div class="text-lg font-semibold leading-tight">Google Play</div>
            </div>
          </a>
          <span class="text-sm text-stone-400">Coming soon</span>
        </div>
      </div>
    </section>

    <!-- What the app does -->
    <section class="mb-16">
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="p-6 bg-stone-50 rounded-lg border border-stone-200">
          <div class="text-teal-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-stone-900 mb-2">Automatic tracking</h3>
          <p class="text-sm text-stone-600">Clock in and out automatically via geofencing when you arrive at or leave your workplace.</p>
        </div>
        <div class="p-6 bg-stone-50 rounded-lg border border-stone-200">
          <div class="text-teal-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="font-semibold text-stone-900 mb-2">Privacy by design</h3>
          <p class="text-sm text-stone-600">Your data stays on your device. Only anonymized, aggregated statistics are shared — never individual records.</p>
        </div>
        <div class="p-6 bg-stone-50 rounded-lg border border-stone-200">
          <div class="text-teal-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-stone-900 mb-2">Collective insights</h3>
          <p class="text-sm text-stone-600">See how your hours compare to others in your region and specialty — powered by differential privacy.</p>
        </div>
      </div>
    </section>

    <!-- Learn more -->
    <section class="text-center">
      <a href="/" class="text-teal-600 hover:text-teal-700 font-medium">
        Learn more about Open Working Hours &rarr;
      </a>
    </section>
  </div>
</Layout>
