---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Download" description="Track working hours transparently and anonymously. For healthcare workers.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Header -->
    <header class="mb-12 text-center">
      <h1 class="text-stone-900 mb-4">Get Open Working Hours</h1>
      <p class="text-xl text-stone-600 max-w-2xl mx-auto">
        Privacy-first working hours tracking for healthcare professionals. Track your shifts, contribute to collective insights — anonymously.
      </p>
    </header>

    <!-- Store badges (official artwork) -->
    <section class="mb-16">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <!-- App Store badge -->
        <div class="flex flex-col items-center gap-2">
          <a href="https://apps.apple.com/app/open-working-hours/id6755491395" target="_blank" rel="noopener" aria-label="Download on the App Store">
            <img src="/badges/app-store-en.svg" alt="Download on the App Store" class="h-14 w-auto" />
          </a>
          <span class="text-sm text-stone-400">iPhone</span>
        </div>

        <!-- Google Play badge -->
        <div class="flex flex-col items-center gap-2">
          <img src="/badges/google-play-en.png" alt="Get it on Google Play" class="h-14 w-auto opacity-40" />
          <span class="text-sm text-stone-400">Coming soon</span>
        </div>
      </div>
    </section>

    <!-- What the app does -->
    <section class="mb-16">
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="p-6 bg-stone-50 rounded-lg border border-stone-200">
          <div class="text-teal-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-stone-900 mb-2">Automatic tracking</h3>
          <p class="text-sm text-stone-600">Clock in and out automatically via geofencing when you arrive at or leave your workplace.</p>
        </div>
        <div class="p-6 bg-stone-50 rounded-lg border border-stone-200">
          <div class="text-teal-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="font-semibold text-stone-900 mb-2">Privacy by design</h3>
          <p class="text-sm text-stone-600">Geofencing runs locally — your precise location never leaves the device; workplace search is optional and sends only an approximate (~1 km) location to Komoot/Photon in Germany. Only anonymized, aggregated statistics are shared, never individual records.</p>
        </div>
        <div class="p-6 bg-stone-50 rounded-lg border border-stone-200">
          <div class="text-teal-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-stone-900 mb-2">Collective insights</h3>
          <p class="text-sm text-stone-600">See how your hours compare to others in your region and specialty — powered by differential privacy.</p>
        </div>
      </div>
    </section>

    <!-- Learn more -->
    <section class="text-center">
      <a href="/" class="text-teal-600 hover:text-teal-700 font-medium">
        Learn more about Open Working Hours &rarr;
      </a>
    </section>
  </div>
</Layout>
